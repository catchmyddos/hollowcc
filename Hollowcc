    if not target or not IsValidTarget(target) then return end
    
    if Shoomedaware.Checks.WallCheck and not IsTargetVisible(target) then return end
    if not IsMouseInTargetFOV(target, Shoomedaware.TriggerBot.FOV) then return end
    
    local char = GetTargetCharacter(target)
    if not char then return end
    
    local virtualPart, realPart, position = GetHitPartDataUniversal(char, Shoomedaware.TriggerBot)
    if not virtualPart then return end
    if IsBehindWall(realPart or virtualPart) then return end
    
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    local toolName = tool.Name:lower()
    if toolName:find("katana") or toolName:find("knife") then return end
    
    local now = tick()
    local cooldownCfg = Shoomedaware.TriggerBot.Cooldown
    
    if cooldownCfg.Enabled then
        local cooldownTime = cooldownCfg.MinCooldown + (math.random() * (cooldownCfg.MaxCooldown - cooldownCfg.MinCooldown))
        if now - TriggerBotState.LastFireTime < cooldownTime then
            return
        end
    end
    
    if tool and tool.Parent then
        tool:Activate()
        TriggerBotState.LastFireTime = now
    end
end))

-- ============================================
-- AIM ASSIST / CAMLOCK (WITH SMOOTH DEATH LOCK)
-- ============================================

local SmoothedVelocity = Vector3.new(0, 0, 0)
local LastTargetPosition = nil
local AimStabilityFrames = 0
local DeathLockPosition = nil
local DeathLockActive = false

local function ShouldCamlockWork()
    local isShiftLock = (UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter)
    local char = LocalPlayer.Character
    if not char then return false end
    local head = char:FindFirstChild("Head")
    if not head then return false end
    local camPos = Camera.CFrame.Position
    local headPos = head.Position
    local distance = (camPos - headPos).Magnitude
    return distance < 2.5 or isShiftLock
end

local function GetAimPosition(char)
    if not char then return nil end
    
    local hitPartSetting = Shoomedaware.AimAssist['Hit Part']
    
    if hitPartSetting == "Closest Point" then
        local data = GetSimpleClosestPoint(char)
        return data and data.Position or nil
    elseif hitPartSetting and hitPartSetting ~= "Closest Point" then
        local part = char:FindFirstChild(hitPartSetting)
        if part and part:IsA("BasePart") then
            return part.Position
        end
    end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.Position end
    
    local head = char:FindFirstChild("Head")
    if head then return head.Position end
    
    return nil
end

local function CalculateSmoothnessAlpha(dt, useDeathLock)
    local smoothnessConfig = Shoomedaware.AimAssist.SmoothnessConfig or {}
    local minSmooth = smoothnessConfig.MinValue or 0.001
    local maxSmooth = smoothnessConfig.MaxValue or 2.0
    
    local userSmoothness = Shoomedaware.AimAssist.Smoothness or 0.75
    local baseSmoothness = math.clamp(userSmoothness, minSmooth, maxSmooth)
    
    local smoothness = baseSmoothness
    if smoothnessConfig.UseDistanceScaling and DeathLockPosition then
        local distance = (Camera.CFrame.Position - DeathLockPosition).Magnitude
        local distanceFactor = math.clamp(distance / 100, 0.5, 2)
        smoothness = baseSmoothness * distanceFactor
    end
    
    if not useDeathLock then
        local legit = Shoomedaware.AimAssist.LegitFeatures
        if legit.Enabled and legit.SmoothnessRandomization.Enabled then
            local randMin = legit.SmoothnessRandomization.Min or 0.12
            local randMax = legit.SmoothnessRandomization.Max or 0.18
            smoothness = math.random() * (randMax - randMin) + randMin
        end
    end
    
    local lerpSpeed = math.max(0.1, smoothness * 20)
    local alpha = 1 - math.exp(-lerpSpeed * dt)
    alpha = math.clamp(alpha, 0.001, 1)
    
    if smoothness < 0.1 then
        alpha = math.clamp(1 - smoothness, 0.01, 1)
    end
    
    return alpha
end

local function IsActuallyKnocked(char)
    if not char then return true end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then return true end
    
    if char:GetAttribute("Knocked") == true then return true end
    if char:GetAttribute("Dead") == true then return true end
    
    local knockedVal = char:FindFirstChild("Knocked")
    if knockedVal and knockedVal:IsA("BoolValue") and knockedVal.Value == true then return true end
    
    local deadVal = char:FindFirstChild("Dead")
    if deadVal and deadVal:IsA("BoolValue") and deadVal.Value == true then return true end
    
    if IsBotCharacter(char) then
        return IsBotDead(char)
    end
    
    return false
end

AddConnection(RunService.RenderStepped:Connect(function(deltaTime)
    local dt = math.min(deltaTime, 0.1)
    
    local aimToggle = (Shoomedaware.General.AimAssistMode == "Toggle" and Shoomedaware.AimAssist.Enabled) or 
        (Shoomedaware.General.AimAssistMode == "Hold" and HoldStates.AimAssist)
    local aimAuto = Shoomedaware.General.TargetingMode == "Automatic" and Shoomedaware.AutoTargetActive
    
    if not (aimToggle or aimAuto) then 
        SmoothedVelocity = Vector3.new(0, 0, 0)
        LastTargetPosition = nil
        AimStabilityFrames = 0
        DeathLockPosition = nil
        DeathLockActive = false
        return 
    end
    
    local target = CurrentTarget or CurrentBotTarget
    local char = target and GetTargetCharacter(target)
    local isKnocked = char and IsActuallyKnocked(char)
    
    if DeathLockPosition and (isKnocked or not char) and not Shoomedaware.Checks.KnockCheck then
        DeathLockActive = true
        local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, DeathLockPosition)
        local alpha = CalculateSmoothnessAlpha(dt, true)
        Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, alpha)
        return
    end
    
    DeathLockActive = false
    
    if not target or not char then 
        SmoothedVelocity = Vector3.new(0, 0, 0)
        LastTargetPosition = nil
        AimStabilityFrames = 0
        return 
    end
    
    if not isKnocked then
        if not ShouldCamlockWork() then 
            local pos = GetAimPosition(char)
            if pos then DeathLockPosition = pos end
            return 
        end
        
        if Shoomedaware.Checks.WallCheck and not IsTargetVisible(target) then 
            local pos = GetAimPosition(char)
            if pos then DeathLockPosition = pos end
            return 
        end
        
        if not IsMouseInTargetFOV(target, Shoomedaware.AimAssist.FOV) then 
            local pos = GetAimPosition(char)
            if pos then DeathLockPosition = pos end
            return 
        end
        
        local legit = Shoomedaware.AimAssist.LegitFeatures
        
        if legit.Enabled and legit.ReactionDelay.Enabled then
            local now = tick()
            if now < CamlockState.ReactionDelayEndY then 
                local pos = GetAimPosition(char)
                if pos then DeathLockPosition = pos end
                return 
            end
        end
        
        local currentPos = GetAimPosition(char)
        if not currentPos then 
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then DeathLockPosition = hrp.Position end
            return 
        end
        
        DeathLockPosition = currentPos
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local velocity = hrp and hrp.Velocity or Vector3.new()
        
        SmoothedVelocity = SmoothedVelocity:Lerp(velocity, 0.15)
        
        if SmoothedVelocity.Magnitude > 100 then
            SmoothedVelocity = SmoothedVelocity.Unit * 100
        end
        
        if SmoothedVelocity.Magnitude < 5 then
            SmoothedVelocity = Vector3.new(0, 0, 0)
        end
        
        local velMag = SmoothedVelocity.Magnitude
        local predMultiplier = 1 + (velMag / 200)
        local vectorPred = Vector3.new(
            Shoomedaware.AimAssist.Prediction.X * predMultiplier,
            Shoomedaware.AimAssist.Prediction.Y * predMultiplier * 1.2,
            Shoomedaware.AimAssist.Prediction.Z * predMultiplier
        )
        
        if LastTargetPosition then
            local posDelta = (currentPos - LastTargetPosition).Magnitude
            if posDelta > 50 then
                AimStabilityFrames = 0
            else
                AimStabilityFrames = math.min(AimStabilityFrames + 1, 10)
            end
        end
        LastTargetPosition = currentPos
        
        local stabilityMultiplier = math.min(AimStabilityFrames / 5, 1)
        vectorPred = vectorPred * stabilityMultiplier
        
        local predictedPos = currentPos + (SmoothedVelocity * vectorPred)
        
        if legit.Enabled and legit.Humanization.Enabled then
            local currentTime2 = tick()
            if currentTime2 - CamlockState.LastHumanizationUpdate > legit.Humanization.Frequency then
                CamlockState.HumanizationOffset = Vector3.new(
                    (math.random() - 0.5) * 2 * legit.Humanization.Amount * 0.5,
                    (math.random() - 0.5) * 2 * legit.Humanization.Amount * 0.5,
                    (math.random() - 0.5) * 2 * legit.Humanization.Amount * 0.5
                )
                CamlockState.LastHumanizationUpdate = currentTime2
            end
            predictedPos = predictedPos + CamlockState.HumanizationOffset
        end
        
        local alpha = CalculateSmoothnessAlpha(dt, false)
        
        local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, predictedPos)
        Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, alpha)
    end
end))

