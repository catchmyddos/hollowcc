local function UpdateUI()
    for _, label in pairs(StatusLabels) do
        label:Destroy()
    end
    StatusLabels = {}
    
    local function AddStatus(name, enabled, extra)
        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, 0, 0, 18)
        Label.BackgroundTransparency = 1
        Label.TextSize = 14
        Label.Font = Enum.Font.SourceSansBold
        Label.TextXAlignment = Enum.TextXAlignment.Right
        
        local statusText = enabled and "ON" or "OFF"
        local displayText = name .. ": " .. statusText
        if extra and enabled then
            displayText = displayText .. " | " .. extra
        end
        
        Label.Text = displayText
        Label.TextColor3 = enabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)
        Label.Parent = StatusContainer
        table.insert(StatusLabels, Label)
    end
    
    AddStatus("Silent Aim", State.SilentAim, State.SilentAimTarget and State.SilentAimTarget.Name or nil)
    AddStatus("Camlock", State.Camlock, State.CamlockTarget and State.CamlockTarget.Name or nil)
    AddStatus("Aim Bot", State.AimBot, State.AimBotTarget and State.AimBotTarget.Name or nil)
    AddStatus("Trigger Bot", State.TriggerBot, State.TriggerBotTarget and State.TriggerBotTarget.Name or nil)
    AddStatus("ESP", State.ESP, nil)
    AddStatus("WalkSpeed", State.WalkSpeed, tostring(shared.Saved['P‚Äčl‚Äča‚Äčy‚Äče‚Äčr‚Äč ‚ÄčM‚Äčo‚Äčd‚Äči‚Äčf‚Äči‚Äčc‚Äča‚Äčt‚Äči‚Äčo‚Äčn‚Äčs']['W‚Äča‚Äčl‚Äčk‚Äč ‚ÄčS‚Äčp‚Äče‚Äče‚Äčd']['S‚Äčp‚Äče‚Äče‚Äčd']))
    
