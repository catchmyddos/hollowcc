local function CleanupOldInstance()
    if _G.ShoomedawareActiveConnections then
        for _, conn in ipairs(_G.ShoomedawareActiveConnections) do
            pcall(function() conn:Disconnect() end)
        end
    end
    
    if _G.ShoomedawareActiveDrawings then
        for _, drawing in ipairs(_G.ShoomedawareActiveDrawings) do
            pcall(function() drawing:Remove() end)
        end
    end
    
    if _G.ShoomedawareESPObjects then
        for _, objData in pairs(_G.ShoomedawareESPObjects) do
            if typeof(objData) == "table" then
                for _, drawing in pairs(objData) do
                    pcall(function() drawing:Remove() end)
                end
            end
        end
    end
    
    if _G.ShoomedawareInfoObjects then
        for _, obj in pairs(_G.ShoomedawareInfoObjects) do
            if typeof(obj) == "table" then
                for _, drawing in pairs(obj) do
                    pcall(function() drawing:Remove() end)
                end
            end
        end
    end
    
    if _G.ShoomedawareFOVBoxes then
        for _, box in pairs(_G.ShoomedawareFOVBoxes) do
            pcall(function() box:Remove() end)
        end
    end
    
    _G.Shoomedaware = nil
    _G.ShoomedawareUserConfig = nil
    _G.ShoomedawareActiveConnections = nil
    _G.ShoomedawareActiveDrawings = nil
    _G.ShoomedawareESPObjects = nil
    _G.ShoomedawareInfoObjects = nil
    _G.ShoomedawareFOVBoxes = nil
    _G.ShoomedawareActive = nil
end

if _G.ShoomedawareLoaded then
    print("🔄 Shoomedaware: Cleaning up old instance...")
    CleanupOldInstance()
    task.wait(0.1)
end

