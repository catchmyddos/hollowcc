-- Gun System
function Script:SilentAimFunc(Tool)
    if not Tool then return end
    
    local Ticks = Script.Locals.LastShot or {}
    if not Ticks[Tool.Name] then
        Ticks[Tool.Name] = 0
    end
    
    local Gun = Script:GetGunCategory()
    if not Gun then return end
    
    local WeaponOffset = WeaponInfo.Offsets[Tool.Name]
    local ToolHandle = Tool:WaitForChild("Handle")
    local Cooldown = Tool:WaitForChild("ShootingCooldown").Value
    local Ammo = Tool:WaitForChild("Ammo")
    
    if tick() - Ticks[Tool.Name] < Cooldown then return end
    if Ammo.Value <= 0 then return end
    
    Ticks[Tool.Name] = tick()
    Script.Locals.LastShot = Ticks
    
    if shared.HollowCC_Config['Silent Aim']['Enabled'] and Script.Locals.IsSilentAiming and Script.Locals.SilentAimTarget and Script.Locals.SilentAimTarget.Character then
        local Target = Script.Locals.SilentAimTarget
        local HitPosition = Script:GetHitPosition('Silent')
        
        local ToolEvent = Tool:WaitForChild("RemoteEvent", 2)
        if ToolEvent then
            ToolEvent:FireServer("Shoot")
            
            local ForcedOrigin = Tool:FindFirstChild("Default") and Tool.Default:FindFirstChild("Mesh") and Tool.Default.Mesh:FindFirstChild("Muzzle")
            if ForcedOrigin then
                local Origin = ForcedOrigin.WorldPosition
                ReplicatedStorage.MainEvent:FireServer("ShootGun", ToolHandle, Origin, HitPosition, nil, nil, Workspace:GetServerTimeNow())
            end
            
            ToolEvent:FireServer()
        end
    end
end

function Script:AimAssist()
    local Enabled = shared.HollowCC_Config['Aim Bot']['Enabled'] 
    if not Enabled then return end
    if not Script.Locals.AimAssistTarget or not Script.Locals.AimAssistTarget.Character then return end
    
    local Player = Script.Locals.AimAssistTarget
    local Character = Player.Character
    
    if shared.HollowCC_Config['Conditions']['Player Protected'] and Character:FindFirstChild("Forcefield") then return end
    if shared.HollowCC_Config['Conditions']['Player Knocked'] and CurrentGame.Functions.IsKnocked(Character) then return end
    if shared.HollowCC_Config['Conditions']['Self Knocked'] and CurrentGame.Functions.IsKnocked(Self.Character) then return end
    if shared.HollowCC_Config['Conditions']['Player Grabbed'] and CurrentGame.Functions.IsGrabbed(Player) then return end
    if shared.HollowCC_Config['Conditions']['Chat Focused'] and UserInputService:GetFocusedTextBox() then return end

    local Config = shared.HollowCC_Config['Aim Bot'] 
    local CurrentCamera = Workspace.CurrentCamera
    local Center = Vector2.new(0.5, 0.5)
    local MousePosition = UserInputService:GetMouseLocation()
    local MouseDelta = (MousePosition.X / CurrentCamera.ViewportSize.X - Center.X) * Config['Sensitivity']

    local Smoothing = Config['Stickiness']
    local EasedSmoothing = TweenService:GetValue(Smoothing, Enum.EasingStyle[Config['Easing Style']], Enum.EasingDirection[Config['Easing Direction']])
    local Hit = Script:GetHitPosition("Assist")

    CurrentCamera.CFrame = CurrentCamera.CFrame:Lerp(
        CFrame.new(CurrentCamera.CFrame.Position, Hit) * CFrame.Angles(0, MouseDelta, 0),
        EasedSmoothing
    )
end

-- FIXED: Camlock Function with proper smoothing
function Script:Camlock()
    local Enabled = shared.HollowCC_Config['Camlock']['Enabled'] 
    if not Enabled then return end
    if not Script.Locals.IsCamlocking then return end
    if not ShouldCamlockWork() then return end
    if not Script.Locals.CamlockTarget or not Script.Locals.CamlockTarget.Character then return end
    
    local Player = Script.Locals.CamlockTarget
    local Character = Player.Character
    
    if shared.HollowCC_Config['Conditions']['Player Protected'] and Character:FindFirstChild("Forcefield") then return end
    if shared.HollowCC_Config['Conditions']['Player Knocked'] and CurrentGame.Functions.IsKnocked(Character) then return end
    if shared.HollowCC_Config['Conditions']['Self Knocked'] and CurrentGame.Functions.IsKnocked(Self.Character) then return end
    if shared.HollowCC_Config['Conditions']['Player Grabbed'] and CurrentGame.Functions.IsGrabbed(Player) then return end
    if shared.HollowCC_Config['Conditions']['Chat Focused'] and UserInputService:GetFocusedTextBox() then return end

    local Config = shared.HollowCC_Config['Camlock'] 
    local HitPosition = Script:GetHitPosition("Camlock")
    
    if not HitPosition then return end

    -- Calculate distance to target for shake reduction
    local localRoot = Self.Character and Self.Character:FindFirstChild("HumanoidRootPart")
    local targetRoot = Character:FindFirstChild("HumanoidRootPart")
    if not localRoot or not targetRoot then return end
    
    local distance = (localRoot.Position - targetRoot.Position).Magnitude
    
    -- Adjust smoothness based on distance (closer = more smoothing to reduce shake)
    local baseSmoothness = Config['Smoothness']
    local adjustedSmoothness = baseSmoothness
    
    if Config['ShakeReduction'] then
        if distance < 10 then
            adjustedSmoothness = math.min(baseSmoothness * 2, 0.15) -- More smoothing when close
        elseif distance < 30 then
            adjustedSmoothness = baseSmoothness * 1.5
        end
    end
    
    -- Clamp smoothness
    adjustedSmoothness = math.clamp(adjustedSmoothness, 0.01, 0.2)
    
    -- Apply smooth camlock
    local targetCFrame = CFrame.new(Camera.CFrame.Position, HitPosition)
    
    -- Use lerp for smooth transition
    Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, adjustedSmoothness)
end

function Script:Triggerbot()
    local triggerBotConfig = shared.HollowCC_Config['Trigger Bot']
    if not triggerBotConfig['Enabled'] then return end
    if not Script.Locals.TriggerState then return end
    if not Script.Locals.TriggerbotTarget or not Script.Locals.TriggerbotTarget.Character then return end
    
    local Target = Script.Locals.TriggerbotTarget
    local Character = Target.Character
    local SelfCharacter = Self.Character
    
    if shared.HollowCC_Config['Conditions']['Player Protected'] and Character:FindFirstChild("Forcefield") then return end
    if shared.HollowCC_Config['Conditions']['Player Knocked'] and CurrentGame.Functions.IsKnocked(Character) then return end
    if shared.HollowCC_Config['Conditions']['Self Knocked'] and CurrentGame.Functions.IsKnocked(SelfCharacter) then return end
    
    local Tool = SelfCharacter:FindFirstChildOfClass("Tool")
    if not Tool or Tool.Name == '[Knife]' then return end
    
    local targetDistance = (SelfCharacter.HumanoidRootPart.Position - Character.HumanoidRootPart.Position).Magnitude
    if targetDistance > triggerBotConfig['Max Distance'] then return end
    
    local currentTime = DateTime.now().UnixTimestampMillis
    if currentTime - (Script.Locals.LastTriggerShot or 0) >= triggerBotConfig['Cooldown'] * 1000 then
        Script.Locals.LastTriggerShot = currentTime
        Tool:Activate()
    end
end

function Script:Physics()
    if not Self.Character then return end
    
    -- FIXED: Walkspeed with configurable speed and toggle
    if shared.HollowCC_Config['Player Modifications']['Walk Speed']['Enabled'] and Script.Locals.IsWalkSpeeding then
        local Object, Humanoid, RootPart = Script:ValidateClient(Self)
        if Humanoid and RootPart then
            local speed = shared.HollowCC_Config['Player Modifications']['Walk Speed']['Speed']
            Humanoid.WalkSpeed = speed
        end
    elseif not Script.Locals.IsWalkSpeeding then
        -- Reset to default when toggled off
        local Object, Humanoid, RootPart = Script:ValidateClient(Self)
        if Humanoid then
            Humanoid.WalkSpeed = 16 -- Default walkspeed
        end
    end
    
    if shared.HollowCC_Config['Player Modifications']['No Tripping'] then
        if Self.Character.Humanoid.Health > 1 and Self.Character.Humanoid:GetState() == Enum.HumanoidStateType.FallingDown then
            Self.Character.Humanoid:ChangeState("GettingUp")
        end
    end
end

-- Input Handling
RBXConnection(UserInputService.InputBegan, function(Input, Processed)
    if Processed then return end
    if shared.HollowCC_Config['Conditions']['Chat Focused'] and UserInputService:GetFocusedTextBox() then return end
    
    local Config = shared.HollowCC_Config
    
    local SilentAimKey = Enum.KeyCode[Config['Hotkeys']['Silent Aim']:upper()]
    local SilentAimTargetKey = Enum.KeyCode[Config['Hotkeys']['Silent Aim Target']:upper()]
    local AimAssistKey = Enum.KeyCode[Config['Hotkeys']['Aim Bot']:upper()]
    local WalkSpeedKey = Enum.KeyCode[Config['Hotkeys']['Walk Speed']:upper()]
    local DoubleTapKey = Enum.KeyCode[Config['Hotkeys']['Double Tap']:upper()]
    local TriggerBotTargetKey = Enum.KeyCode[Config['Hotkeys']['Trigger Bot Target']:upper()]
    local HitPartOverrideKey = Enum.KeyCode[Config['Hotkeys']['Hit Part Override']:upper()]
    local ESPKey = Enum.KeyCode[Config['Hotkeys']['ESP']:upper()]
    local CamlockKey = Enum.KeyCode[Config['Hotkeys']['Camlock']:upper()]
    
    -- Silent Aim Toggle
    if Input.KeyCode == SilentAimKey then
        Script.Locals.IsSilentAiming = not Script.Locals.IsSilentAiming
    end
    
    -- Camlock Toggle
    if Input.KeyCode == CamlockKey then
        Script.Locals.IsCamlocking = not Script.Locals.IsCamlocking
        if Script.Locals.IsCamlocking then
            Script.Locals.CamlockTarget = Script:GetClosestPlayerToCursor(
                Config['Camlock']['FOV']['Enabled'] and Config['Camlock']['FOV']['Size'] or math.huge,
                math.huge
            )
        else
            Script.Locals.CamlockTarget = nil
        end
    end
    
    -- ESP Toggle
    if Input.KeyCode == ESPKey then
        Config['ESP']['Enabled'] = not Config['ESP']['Enabled']
    end
    
    -- Hit Part Override
    if Input.KeyCode == HitPartOverrideKey then
        Script.Locals.IsOverriding = not Script.Locals.IsOverriding
    end
    
    -- Silent Aim Target
    if Input.KeyCode == SilentAimTargetKey and Config['Silent Aim']['Selection'] == 'Target' then
        if not Script.Locals.IsSilentAiming then
            Script.Locals.IsSilentAiming = true
            Script.Locals.SilentAimTarget = Script:GetClosestPlayerToCursor(
                Config['Silent Aim']['Max Distance'] * 100,
                Config['Silent Aim']['FOV']['Enabled'] and Config['Silent Aim']['FOV']['Circle'] or math.huge
            )    
        else
            Script.Locals.IsSilentAiming = false
            Script.Locals.SilentAimTarget = nil
        end
    end
    
    -- Trigger Bot Target
    if Input.KeyCode == TriggerBotTargetKey and Config['Trigger Bot']['Selection'] == 'Target' then
        if not Script.Locals.TriggerState then
            Script.Locals.TriggerState = true
            Script.Locals.TriggerbotTarget = Script:GetClosestPlayerToCursor(
                Config['Trigger Bot']['Max Distance'] * 100,
                Config['Trigger Bot']['Radius'] * 5
            )  
        else
            Script.Locals.TriggerState = false
            Script.Locals.TriggerbotTarget = nil
        end
    end
    
    -- Aim Assist
    if Input.KeyCode == AimAssistKey then
        if not Script.Locals.AimAssistTarget then
            Script.Locals.AimAssistTarget = Script:GetClosestPlayerToCursor(
                Config['Silent Aim']['Max Distance'] * 100,
                Config['Aim Bot']['FOV']['Enabled'] and Config['Aim Bot']['FOV']['Size'] or math.huge
            )
        else
            Script.Locals.AimAssistTarget = nil
        end
    end
    
    -- Walk Speed Toggle
    if Input.KeyCode == WalkSpeedKey then
        Script.Locals.IsWalkSpeeding = not Script.Locals.IsWalkSpeeding
        -- Toggle the enabled state in config too
        Config['Player Modifications']['Walk Speed']['Enabled'] = Script.Locals.IsWalkSpeeding
    end
    
    -- Double Tap
    if Input.KeyCode == DoubleTapKey then
        Script.Locals.IsDoubleTapping = not Script.Locals.IsDoubleTapping
    end
    
    -- Trigger Bot Activation
    local triggerKey = Config['Hotkeys']['Trigger Bot']
    if Config['Trigger Bot']['Activation']['Mode'] == 'Keybind' then
        local success, keyCode = pcall(function()
            return Enum.KeyCode[triggerKey:upper()]
        end)
        if success and Input.KeyCode == keyCode then
            if Config['Trigger Bot']['Activation']['Type'] == "Toggle" then
                Script.Locals.TriggerState = not Script.Locals.TriggerState
            elseif Config['Trigger Bot']['Activation']['Type'] == "Hold" then
                Script.Locals.TriggerState = true
            end
        end
    end
    
    if Input.KeyCode == Enum.KeyCode.LeftControl then
        Script.Locals.CanTriggerbotShoot = false
    end
end)

RBXConnection(UserInputService.InputEnded, function(Input)
    local Config = shared.HollowCC_Config
    local triggerKey = Config['Hotkeys']['Trigger Bot']
    
    if Config['Trigger Bot']['Activation']['Type'] == "Hold" and Config['Trigger Bot']['Activation']['Mode'] == 'Keybind' then
        local success, keyCode = pcall(function()
            return Enum.KeyCode[triggerKey:upper()]
        end)
        if success and Input.KeyCode == keyCode then
            Script.Locals.TriggerState = false
        end
    end
    
    if Input.KeyCode == Enum.KeyCode.LeftControl then
        Script.Locals.CanTriggerbotShoot = true
    end
end)

-- Character Setup
local Activated
local function OnLocalCharacterAdded(Character)
    if not Character then return end
    
    Character.ChildAdded:Connect(function(Tool)
        if not Tool:IsA("Tool") then return end
        Activated = Tool.Activated:Connect(function()
            Script:SilentAimFunc(Tool)
        end)
    end)
    
    Character.ChildRemoved:Connect(function(Tool)
        if not Tool:IsA("Tool") then return end
        if Activated then
            Activated:Disconnect()
        end
    end)
end

OnLocalCharacterAdded(Self.Character)
Self.CharacterAdded:Connect(OnLocalCharacterAdded)

