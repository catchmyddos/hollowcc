-- TARGET MANAGEMENT
-- ============================================

local LastTargetUpdate = 0
local LastBotDeathPosition = nil
local WasTargetingBot = false

local function AcquireTarget()
    if Shoomedaware.General.TargetingMode == "Automatic" then return end
    
    local newTarget = GetClosestPlayerToMouse()
    if newTarget then
        CurrentTarget = newTarget
        CurrentBotTarget = nil
        TargetAcquiredTime = tick()
        WasTargetingBot = false
        return true
    end
    
    if Shoomedaware.General.TargetBots then
        local newBot = GetClosestBotToMouse()
        if newBot then
            CurrentTarget = nil
            CurrentBotTarget = newBot
            TargetAcquiredTime = tick()
            WasTargetingBot = true
            return true
        end
    end
    
    return false
end

AddConnection(RunService.RenderStepped:Connect(function()
    local now = tick()
    if now - LastTargetUpdate < 0.05 then return end
    LastTargetUpdate = now
    
    if CurrentBotTarget then
        if not CurrentBotTarget.Parent then
            if DeathLockPosition and WasTargetingBot then
                LastBotDeathPosition = DeathLockPosition
            end
            CurrentBotTarget = nil
            WasTargetingBot = false
        elseif IsBotDead(CurrentBotTarget) then
            local char = CurrentBotTarget
            local hitPartSetting = Shoomedaware.AimAssist['Hit Part']
            local deathPos = nil
            
            if hitPartSetting == "Closest Point" then
                local data = GetSimpleClosestPoint(char)
                if data then deathPos = data.Position end
            elseif hitPartSetting and hitPartSetting ~= "Closest Point" then
                local part = char:FindFirstChild(hitPartSetting)
                if part then deathPos = part.Position end
            else
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then deathPos = hrp.Position end
            end
            
            if deathPos then
                LastBotDeathPosition = deathPos
                DeathLockPosition = deathPos
            end
            
            if Shoomedaware.Checks.KnockCheck then
                CurrentBotTarget = nil
                WasTargetingBot = false
            end
        end
    end
    
    if CurrentTarget and not IsValidTarget(CurrentTarget) then
        CurrentTarget = nil
        if Shoomedaware.General.TargetingMode == "Automatic" then
            Shoomedaware.AutoTargetActive = false
        end
    end
    
    if Shoomedaware.General.TargetingMode == "Automatic" then
        local closestPlayer = nil
        local closestBot = nil
        local playerDist, botDist = math.huge, math.huge
        local mousePos = UserInputService:GetMouseLocation()
        
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local char = plr.Character
                local hum = char:FindFirstChildOfClass("Humanoid")
                local hrp = char:FindFirstChild("HumanoidRootPart")
                
                if hum and hrp and hum.Health > 0 then
                    local pos = Camera:WorldToViewportPoint(hrp.Position)
                    if pos.Z > 0 then
                        local d = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                        if d < playerDist then 
                            playerDist = d 
                            closestPlayer = plr 
                        end
                    end
                end
            end
        end
        
        if Shoomedaware.General.TargetBots then
            for botChar, _ in pairs(BotCache) do
                if botChar and botChar.Parent and not IsBotDead(botChar) then
                    local hrp = botChar:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local pos = Camera:WorldToViewportPoint(hrp.Position)
                        if pos.Z > 0 then
                            local d = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                            if d < botDist then 
                                botDist = d 
                                closestBot = botChar 
                            end
                        end
                    end
                end
            end
        end
        
        if closestPlayer and closestBot then
            if playerDist < botDist then
                CurrentTarget = closestPlayer
                CurrentBotTarget = nil
                WasTargetingBot = false
            else
                CurrentTarget = nil
                CurrentBotTarget = closestBot
                WasTargetingBot = true
            end
        elseif closestPlayer then
            CurrentTarget = closestPlayer
            CurrentBotTarget = nil
            WasTargetingBot = false
        elseif closestBot then
            CurrentTarget = nil
            CurrentBotTarget = closestBot
            WasTargetingBot = true
        else
            CurrentTarget = nil
            CurrentBotTarget = nil
            WasTargetingBot = false
        end
        
        Shoomedaware.AutoTargetActive = (CurrentTarget ~= nil or CurrentBotTarget ~= nil)
    else
        local aimActive = (Shoomedaware.General.AimAssistMode == "Toggle" and Shoomedaware.AimAssist.Enabled) or 
            (Shoomedaware.General.AimAssistMode == "Hold" and HoldStates.AimAssist)
        local triggerActive = (Shoomedaware.General.TriggerBotMode == "Toggle" and Shoomedaware.TriggerBot.Enabled) or 
            (Shoomedaware.General.TriggerBotMode == "Hold" and HoldStates.TriggerBot)
        local silentActive = Shoomedaware.SilentAim.Enabled
        
        if not (silentActive or aimActive or triggerActive) then
            CurrentTarget = nil
            CurrentBotTarget = nil
            Shoomedaware.AcquireNewTarget = false
            WasTargetingBot = false
        elseif not CurrentTarget and not CurrentBotTarget then
            if Shoomedaware.AcquireNewTarget then
                AcquireTarget()
                Shoomedaware.AcquireNewTarget = false
            end
        end
    end
end))

