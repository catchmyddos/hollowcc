local function UpdateESP()
    if not shared.HollowCC_Config['ESP']['Enabled'] then
        for _, obj in pairs(Script.Locals.ESPObjects) do
            for _, visual in pairs(obj) do
                if visual and typeof(visual) == "Instance" then
                    visual.Visible = false
                elseif visual and typeof(visual) == "table" and visual.Remove then
                    visual.Visible = false
                end
            end
        end
        return
    end
    
    local localPlayer = Self
    local localCharacter = localPlayer.Character
    if not localCharacter then return end
    
    local localRoot = localCharacter:FindFirstChild("HumanoidRootPart")
    local localHumanoid = localCharacter:FindFirstChild("Humanoid")
    if not localRoot or not localHumanoid then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == localPlayer then continue end
        
        if not Script.Locals.ESPObjects[player] then
            Script.Locals.ESPObjects[player] = CreateESPObject(player)
        end
        
        local objects = Script.Locals.ESPObjects[player]
        local character = player.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid = character and character:FindFirstChild("Humanoid")
        
        if not character or not root or not humanoid then
            for _, obj in pairs(objects) do
                if obj and typeof(obj) == "Instance" then
                    obj.Visible = false
                elseif obj and typeof(obj) == "table" and obj.Visible ~= nil then
                    obj.Visible = false
                end
            end
            continue
        end
        
        local distance = (localRoot.Position - root.Position).Magnitude
        if distance > shared.HollowCC_Config['ESP']['Max Distance'] then
            for _, obj in pairs(objects) do
                if obj and typeof(obj) == "Instance" then
                    obj.Visible = false
                elseif obj and typeof(obj) == "table" and obj.Visible ~= nil then
                    obj.Visible = false
                end
            end
            continue
        end
        
        -- Get head and foot positions
        local head = character:FindFirstChild("Head")
        local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
        
        if not head or not torso then
            for _, obj in pairs(objects) do
                if obj and typeof(obj) == "Instance" then
                    obj.Visible = false
                elseif obj and typeof(obj) == "table" and obj.Visible ~= nil then
                    obj.Visible = false
                end
            end
            continue
        end
        
        local headPos = Camera:WorldToViewportPoint(head.Position)
        local footPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
        
        if headPos.Z < 0 or footPos.Z < 0 then
            for _, obj in pairs(objects) do
                if obj and typeof(obj) == "Instance" then
                    obj.Visible = false
                elseif obj and typeof(obj) == "table" and obj.Visible ~= nil then
                    obj.Visible = false
                end
            end
            continue
        end
        
        local height = math.abs(headPos.Y - footPos.Y)
        local width = height * 0.6
        local x = headPos.X - width / 2
        local y = headPos.Y
        
        -- Update Box
        if objects.Box then
            objects.Box.Visible = true
            objects.Box.Size = UDim2.new(0, width, 0, height)
            objects.Box.Position = UDim2.new(0, x, 0, y)
            
            -- Update corners
            if objects.Corner1 then
                objects.Corner1.Visible = true
                objects.Corner1.Position = UDim2.new(0, x, 0, y)
            end
            if objects.Corner2 then
                objects.Corner2.Visible = true
                objects.Corner2.Position = UDim2.new(0, x + width - 6, 0, y)
            end
            if objects.Corner3 then
                objects.Corner3.Visible = true
                objects.Corner3.Position = UDim2.new(0, x, 0, y)
            end
            if objects.Corner4 then
                objects.Corner4.Visible = true
                objects.Corner4.Position = UDim2.new(0, x + width - 2, 0, y)
            end
        end
        
        -- Update Name
        if objects.Name then
            objects.Name.Visible = true
            objects.Name.Text = player.DisplayName
            objects.Name.Position = UDim2.new(0, headPos.X - 50, 0, y - 20)
            objects.Name.Size = UDim2.new(0, 100, 0, 15)
        end
        
        -- Update Health
        if objects.HealthBar and objects.HealthBarBG then
            local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
            objects.HealthBarBG.Visible = true
            objects.HealthBarBG.Size = UDim2.new(0, 4, 0, height)
            objects.HealthBarBG.Position = UDim2.new(0, x - 8, 0, y)
            
            objects.HealthBar.Visible = true
            objects.HealthBar.Size = UDim2.new(0, 4, 0, height * healthPercent)
            objects.HealthBar.Position = UDim2.new(0, x - 8, 0, y + height * (1 - healthPercent))
            objects.HealthBar.BackgroundColor3 = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
        end
        
        -- Update Tracer
        if objects.Tracer then
            objects.Tracer.Visible = true
            local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            local targetPos = Vector2.new(x + width / 2, y + height)
            objects.Tracer.From = screenCenter
            objects.Tracer.To = targetPos
        end
        
        -- Update Distance
        if objects.Distance then
            objects.Distance.Visible = true
            objects.Distance.Text = math.floor(distance) .. " studs"
            objects.Distance.Position = UDim2.new(0, x, 0, y + height + 2)
            objects.Distance.Size = UDim2.new(0, width, 0, 15)
        end
    end
end

-- Drawing Library
do
    local CustomLibIndex = 0
    local UtilityUI = Instance.new('ScreenGui')
    UtilityUI.Parent = game:GetService("CoreGui")
    UtilityUI.IgnoreGuiInset = true
    local Clamp = math.clamp
    local LibraryMeta = {
        Visible = true,
        ZIndex = 0,
        Transparency = 1,
        Color = Color3.new(),
        Remove = function(self) setmetatable(self, nil) end,
        Destroy = function(self) setmetatable(self, nil) end
    }

    function Script.Visuals.new(ClassType)
        CustomLibIndex += 1
        if ClassType == 'Line' then
            local LineObject = {
                From = Vector2.zero,
                To = Vector2.zero,
                Thickness = 1
            }
            for k, v in pairs(LibraryMeta) do LineObject[k] = v end
            
            local Line = Instance.new('Frame')
            Line.Name = CustomLibIndex
            Line.AnchorPoint = Vector2.one * 0.5
            Line.BorderSizePixel = 0
            Line.BackgroundColor3 = LineObject.Color
            Line.Visible = LineObject.Visible
            Line.ZIndex = LineObject.ZIndex
            Line.BackgroundTransparency = 1 - LineObject.Transparency
            Line.Size = UDim2.new()
            Line.Parent = UtilityUI

            return setmetatable({}, {
                __newindex = function(_, Property, Value)
                    if Property == 'From' then
                        local Direction = LineObject.To - Value
                        local Center = (LineObject.To + Value) / 2
                        local Magnitude = Direction.Magnitude
                        local Theta = math.deg(math.atan2(Direction.Y, Direction.X))
                        Line.Position = UDim2.fromOffset(Center.X, Center.Y)
                        Line.Rotation = Theta
                        Line.Size = UDim2.fromOffset(Magnitude, LineObject.Thickness)
                    elseif Property == 'To' then
                        local Direction = Value - LineObject.From
                        local Center = (Value + LineObject.From) / 2
                        local Magnitude = Direction.Magnitude
                        local Theta = math.deg(math.atan2(Direction.Y, Direction.X))
                        Line.Position = UDim2.fromOffset(Center.X, Center.Y)
                        Line.Rotation = Theta
                        Line.Size = UDim2.fromOffset(Magnitude, LineObject.Thickness)
                    elseif Property == 'Thickness' then
                        Line.Size = UDim2.fromOffset((LineObject.To - LineObject.From).Magnitude, Value)
                    elseif Property == 'Visible' then
                        Line.Visible = Value
                    elseif Property == 'ZIndex' then
                        Line.ZIndex = Value
                    elseif Property == 'Transparency' then
                        Line.BackgroundTransparency = 1 - Value
                    elseif Property == 'Color' then
                        Line.BackgroundColor3 = Value
                    end
                    LineObject[Property] = Value
                end,
                __index = function(self, index)
                    if index == 'Remove' or index == 'Destroy' then
                        return function()
                            Line:Destroy()
                            return LineObject:Remove()
                        end
                    end
                    return LineObject[index]
                end
            })
        elseif ClassType == 'Circle' then
            local circleObj = {
                Radius = 150,
                Position = Vector2.zero,
                Thickness = 0.7,
                Filled = false
            }
            for k, v in pairs(LibraryMeta) do circleObj[k] = v end

            local circleFrame = Instance.new('Frame')
            local uiCorner = Instance.new('UICorner')
            local uiStroke = Instance.new('UIStroke')
            
            circleFrame.Name = CustomLibIndex
            circleFrame.AnchorPoint = Vector2.one * 0.5
            circleFrame.BorderSizePixel = 0
            circleFrame.BackgroundTransparency = circleObj.Filled and (1 - circleObj.Transparency) or 1
            circleFrame.BackgroundColor3 = circleObj.Color
            circleFrame.Visible = circleObj.Visible
            circleFrame.ZIndex = circleObj.ZIndex
            uiCorner.CornerRadius = UDim.new(1, 0)
            circleFrame.Size = UDim2.fromOffset(circleObj.Radius, circleObj.Radius)
            uiStroke.Thickness = circleObj.Thickness
            uiStroke.Enabled = not circleObj.Filled
            uiStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

            circleFrame.Parent = UtilityUI
            uiCorner.Parent = circleFrame
            uiStroke.Parent = circleFrame

            return setmetatable({}, {
                __newindex = function(_, index, value)
                    if index == 'Radius' then
                        circleFrame.Size = UDim2.fromOffset(value * 2, value * 2)
                    elseif index == 'Position' then
                        circleFrame.Position = UDim2.fromOffset(value.X, value.Y)
                    elseif index == 'Thickness' then
                        uiStroke.Thickness = Clamp(value, 0.6, 0x7fffffff)
                    elseif index == 'Filled' then
                        circleFrame.BackgroundTransparency = circleObj.Filled and (1 - circleObj.Transparency) or 1
                        uiStroke.Enabled = not value
                    elseif index == 'Visible' then
                        circleFrame.Visible = value
                    elseif index == 'ZIndex' then
                        circleFrame.ZIndex = value
                    elseif index == 'Transparency' then
                        circleFrame.BackgroundTransparency = circleObj.Filled and (1 - value) or 1
                        uiStroke.Transparency = 1 - value
                    elseif index == 'Color' then
                        circleFrame.BackgroundColor3 = value
                        uiStroke.Color = value
                    end
                    circleObj[index] = value
                end,
                __index = function(self, index)
                    if index == 'Remove' or index == 'Destroy' then
                        return function()
                            circleFrame:Destroy()
                            return circleObj:Remove()
                        end
                    end
                    return circleObj[index]
                end
            })
        elseif ClassType == 'Square' then
            local squareObj = {
                Size = Vector2.zero,
                Position = Vector2.zero,
                Thickness = 0.7,
                Filled = false
            }
            for k, v in pairs(LibraryMeta) do squareObj[k] = v end

            local squareFrame = Instance.new('Frame')
            local uiStroke = Instance.new('UIStroke')
            
            squareFrame.Name = CustomLibIndex
            squareFrame.BorderSizePixel = 0
            squareFrame.BackgroundTransparency = 1
            squareFrame.ZIndex = squareObj.ZIndex
            squareFrame.BackgroundColor3 = squareObj.Color
            squareFrame.Visible = squareObj.Visible
            uiStroke.Thickness = squareObj.Thickness
            uiStroke.Enabled = not squareObj.Filled
            uiStroke.LineJoinMode = Enum.LineJoinMode.Miter

            squareFrame.Parent = UtilityUI
            uiStroke.Parent = squareFrame

            return setmetatable({}, {
                __newindex = function(_, index, value)
                    if index == 'Size' then
                        squareFrame.Size = UDim2.fromOffset(value.X, value.Y)
                    elseif index == 'Position' then
                        squareFrame.Position = UDim2.fromOffset(value.X, value.Y)
                    elseif index == 'Thickness' then
                        uiStroke.Thickness = Clamp(value, 0.6, 0x7fffffff)
                    elseif index == 'Visible' then
                        squareFrame.Visible = value
                    elseif index == 'Transparency' then
                        uiStroke.Transparency = 1 - value
                    elseif index == 'Color' then
                        uiStroke.Color = value
                        squareFrame.BackgroundColor3 = value
                    end
                    squareObj[index] = value
                end,
                __index = function(self, index)
                    if index == 'Remove' or index == 'Destroy' then
                        return function()
                            squareFrame:Destroy()
                            return squareObj:Remove()
                        end
                    end
                    return squareObj[index]
                end
            })
        elseif ClassType == 'Text' then
            local textObj = {
                Text = '',
                Font = Enum.Font.SourceSansBold,
                Size = 0,
                Position = Vector2.zero,
                Center = false,
                Outline = false,
                OutlineColor = Color3.new()
            }
            for k, v in pairs(LibraryMeta) do textObj[k] = v end

            local textLabel = Instance.new('TextLabel')
            local uiStroke = Instance.new('UIStroke')
            
            textLabel.Name = CustomLibIndex
            textLabel.AnchorPoint = Vector2.one * 0.5
            textLabel.BorderSizePixel = 0
            textLabel.BackgroundTransparency = 1
            textLabel.RichText = true
            textLabel.Visible = textObj.Visible
            textLabel.TextColor3 = textObj.Color
            textLabel.TextTransparency = 1 - textObj.Transparency
            textLabel.ZIndex = textObj.ZIndex
            textLabel.Font = Enum.Font.SourceSansBold
            textLabel.TextSize = textObj.Size

            textLabel:GetPropertyChangedSignal('TextBounds'):Connect(function()
                local textBounds = textLabel.TextBounds
                local offset = textBounds / 2
                local offsetX = textObj.Center and 0 or offset.X
                textLabel.Position = UDim2.fromOffset(textObj.Position.X + offsetX, textObj.Position.Y + offset.Y)
            end)

            uiStroke.Thickness = 1
            uiStroke.Enabled = textObj.Outline
            uiStroke.Color = textObj.Color

            textLabel.Parent = UtilityUI
            uiStroke.Parent = textLabel

            return setmetatable({}, {
                __newindex = function(_, index, value)
                    if index == 'Text' then
                        textLabel.Text = value
                    elseif index == 'Size' then
                        textLabel.TextSize = value
                    elseif index == 'Position' then
                        local offset = textLabel.TextBounds / 2
                        local offsetX = textObj.Center and 0 or offset.X
                        textLabel.Position = UDim2.fromOffset(textObj.Position.X + offsetX, textObj.Position.Y + offset.Y)
                    elseif index == 'Center' then
                        local position = value and Camera.ViewportSize / 2 or textObj.Position
                        textLabel.Position = UDim2.fromOffset(position.X, position.Y)
                    elseif index == 'Outline' then
                        uiStroke.Enabled = value
                    elseif index == 'OutlineColor' then
                        uiStroke.Color = value
                    elseif index == 'Visible' then
                        textLabel.Visible = value
                    elseif index == 'ZIndex' then
                        textLabel.ZIndex = value
                    elseif index == 'Transparency' then
                        textLabel.TextTransparency = 1 - value
                        uiStroke.Transparency = 1 - value
                    elseif index == 'Color' then
                        textLabel.TextColor3 = value
                    end
                    textObj[index] = value
                end,
                __index = function(self, index)
                    if index == 'Remove' or index == 'Destroy' then
                        return function()
                            textLabel:Destroy()
                            return textObj:Remove()
                        end
                    elseif index == 'TextBounds' then
                        return textLabel.TextBounds
                    end
                    return textObj[index]
                end
            })
        end
    end
end

