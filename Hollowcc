local function GetCameraMode()
    local zoom = (Camera.CFrame.Position - Camera.Focus.Position).Magnitude
    local isFirstPerson = zoom < 1.5
    local isShiftLocked = UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter
    
    return {
        FirstPerson = isFirstPerson,
        ThirdPerson = not isFirstPerson,
        ShiftLocked = isShiftLocked
    }
end

local function ShouldCamlockWork()
    local mode = GetCameraMode()
    local config = shared.Saved['C‚Äčo‚Äčn‚Äčd‚Äči‚Äčt‚Äči‚Äčo‚Äčn‚Äčs']
    
    if mode.ThirdPerson and not mode.ShiftLocked and not config['T‚Äčh‚Äči‚Äčr‚Äčd‚Äč ‚ÄčP‚Äče‚Äčr‚Äčs‚Äčo‚Äčn‚Äč ‚ÄčC‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk'] then
        return false
    end
    
    if mode.FirstPerson and config['F‚Äči‚Äčr‚Äčs‚Äčt‚Äč ‚ÄčP‚Äče‚Äčr‚Äčs‚Äčo‚Äčn‚Äč ‚ÄčC‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk'] then
        return true
    end
    
    if mode.ShiftLocked and config['S‚Äčh‚Äči‚Äčf‚Äčt‚ÄčL‚Äčo‚Äčc‚Äčk‚Äč ‚ÄčC‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk'] then
        return true
    end
    
    if mode.ThirdPerson and config['T‚Äčh‚Äči‚Äčr‚Äčd‚Äč ‚ÄčP‚Äče‚Äčr‚Äčs‚Äčo‚Äčn‚Äč ‚ÄčC‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk'] then
        return true
    end
    
    return false
end

