-- Status Labels
local StatusLabels = {}

local function UpdateUI()
    -- Clear old
    for _, label in pairs(StatusLabels) do
        label:Destroy()
    end
    StatusLabels = {}
    
    local function AddStatus(text, enabled, extra)
        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, 0, 0, 18)
        Label.BackgroundTransparency = 1
        Label.TextSize = 14
        Label.Font = Enum.Font.SourceSansBold -- Bold
        Label.TextXAlignment = Enum.TextXAlignment.Right
        
        local statusText = enabled and "ON" or "OFF"
        local displayText = text .. ": " .. statusText
        if extra and enabled then
            displayText = displayText .. " | " .. extra
        end
        
        Label.Text = displayText
        Label.TextColor3 = enabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)
        Label.Parent = StatusContainer
        table.insert(StatusLabels, Label)
    end
    
    AddStatus("Silent Aim", Config.SilentAim, State.SilentAimTarget and State.SilentAimTarget.DisplayName or nil)
    AddStatus("Camlock", Config.Camlock, State.CamlockTarget and State.CamlockTarget.DisplayName or nil)
    AddStatus("ESP", Config.ESP, nil)
    AddStatus("WalkSpeed", Config.WalkSpeedEnabled, tostring(Config.WalkSpeed))
    
    -- Adjust height
    MainFrame.Size = UDim2.new(0, 180, 0, 30 + (#StatusLabels * 22))
end

-- ESP System
local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "ESP"
ESPFolder.Parent = ScreenGui
State.ESPFolder = ESPFolder

local function CreateESP(player)
    local esp = {}
    
    -- Corner box (4 lines)
    for i = 1, 4 do
        local line = Instance.new("Frame")
        line.BackgroundColor3 = Config.ESPColor
        line.BorderSizePixel = 0
        line.Visible = false
        line.Parent = ESPFolder
        esp["Line" .. i] = line
    end
    
    -- Name
    local name = Instance.new("TextLabel")
    name.BackgroundTransparency = 1
    name.TextColor3 = Config.ESPColor
    name.TextSize = 13
    name.Font = Enum.Font.SourceSansBold
    name.Visible = false
    name.Parent = ESPFolder
    esp.Name = name
    
    -- Health bar
    local healthBg = Instance.new("Frame")
    healthBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    healthBg.BorderSizePixel = 0
    healthBg.Visible = false
    healthBg.Parent = ESPFolder
    
    local healthBar = Instance.new("Frame")
    healthBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    healthBar.BorderSizePixel = 0
    healthBar.Visible = false
    healthBar.Parent = ESPFolder
    
    esp.HealthBg = healthBg
    esp.HealthBar = healthBar
    
    -- Distance
    local dist = Instance.new("TextLabel")
    dist.BackgroundTransparency = 1
    dist.TextColor3 = Config.ESPColor
    dist.TextSize = 11
    dist.Font = Enum.Font.SourceSansBold
    dist.Visible = false
    dist.Parent = ESPFolder
    dist.Text = ""
    esp.Distance = dist
    
    return esp
end

local function UpdateESP()
    if not Config.ESP then
        for _, esp in pairs(State.ESPObjects) do
            for _, v in pairs(esp) do
                if typeof(v) == "Instance" then
                    v.Visible = false
                end
            end
        end
        return
    end
    
    local localChar = LocalPlayer.Character
    if not localChar then return end
    local localRoot = localChar:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        
        if not State.ESPObjects[player] then
            State.ESPObjects[player] = CreateESP(player)
        end
        
        local esp = State.ESPObjects[player]
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChild("Humanoid")
        local head = char and char:FindFirstChild("Head")
        
        if not char or not root or not humanoid or not head then
            for _, v in pairs(esp) do
                if typeof(v) == "Instance" then
                    v.Visible = false
                end
            end
            continue
        end
        
        local distance = (localRoot.Position - root.Position).Magnitude
        if distance > Config.ESPMaxDistance then
            for _, v in pairs(esp) do
                if typeof(v) == "Instance" then
                    v.Visible = false
                end
            end
            continue
        end
        
        local headPos = Camera:WorldToViewportPoint(head.Position)
        local footPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
        
        if headPos.Z < 0 then
            for _, v in pairs(esp) do
                if typeof(v) == "Instance" then
                    v.Visible = false
                end
            end
            continue
        end
        
        local height = math.abs(headPos.Y - footPos.Y)
        local width = height * 0.6
        local x = headPos.X - width / 2
        local y = headPos.Y
        
        -- Draw corner box
        local lineThickness = 1
        
        -- Top left
        esp.Line1.Size = UDim2.new(0, width * 0.4, 0, lineThickness)
        esp.Line1.Position = UDim2.new(0, x, 0, y)
        esp.Line1.Visible = true
        
        esp.Line2.Size = UDim2.new(0, lineThickness, 0, height * 0.4)
        esp.Line2.Position = UDim2.new(0, x, 0, y)
        esp.Line2.Visible = true
        
        -- Top right
        esp.Line3.Size = UDim2.new(0, width * 0.4, 0, lineThickness)
        esp.Line3.Position = UDim2.new(0, x + width * 0.6, 0, y)
        esp.Line3.Visible = true
        
        esp.Line4.Size = UDim2.new(0, lineThickness, 0, height * 0.4)
        esp.Line4.Position = UDim2.new(0, x + width - lineThickness, 0, y)
        esp.Line4.Visible = true
        
        -- Bottom left
        local line5 = esp["Line5"] or Instance.new("Frame")
        if not esp["Line5"] then
            line5.BackgroundColor3 = Config.ESPColor
            line5.BorderSizePixel = 0
            line5.Parent = ESPFolder
            esp["Line5"] = line5
        end
        line5.Size = UDim2.new(0, width * 0.4, 0, lineThickness)
        line5.Position = UDim2.new(0, x, 0, y + height - lineThickness)
        line5.Visible = true
        
        local line6 = esp["Line6"] or Instance.new("Frame")
        if not esp["Line6"] then
            line6.BackgroundColor3 = Config.ESPColor
            line6.BorderSizePixel = 0
            line6.Parent = ESPFolder
            esp["Line6"] = line6
        end
        line6.Size = UDim2.new(0, lineThickness, 0, height * 0.4)
        line6.Position = UDim2.new(0, x, 0, y + height * 0.6)
        line6.Visible = true
        
        -- Bottom right
        local line7 = esp["Line7"] or Instance.new("Frame")
        if not esp["Line7"] then
            line7.BackgroundColor3 = Config.ESPColor
            line7.BorderSizePixel = 0
            line7.Parent = ESPFolder
            esp["Line7"] = line7
        end
        line7.Size = UDim2.new(0, width * 0.4, 0, lineThickness)
        line7.Position = UDim2.new(0, x + width * 0.6, 0, y + height - lineThickness)
        line7.Visible = true
        
        local line8 = esp["Line8"] or Instance.new("Frame")
        if not esp["Line8"] then
            line8.BackgroundColor3 = Config.ESPColor
            line8.BorderSizePixel = 0
            line8.Parent = ESPFolder
            esp["Line8"] = line8
        end
        line8.Size = UDim2.new(0, lineThickness, 0, height * 0.4)
        line8.Position = UDim2.new(0, x + width - lineThickness, 0, y + height * 0.6)
        line8.Visible = true
        
        -- Name
        esp.Name.Text = player.DisplayName
        esp.Name.Position = UDim2.new(0, headPos.X - 50, 0, y - 20)
        esp.Name.Size = UDim2.new(0, 100, 0, 15)
        esp.Name.Visible = true
        
        -- Health bar
        local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
        esp.HealthBg.Size = UDim2.new(0, 4, 0, height)
        esp.HealthBg.Position = UDim2.new(0, x - 8, 0, y)
        esp.HealthBg.Visible = true
        
        esp.HealthBar.Size = UDim2.new(0, 4, 0, height * healthPercent)
        esp.HealthBar.Position = UDim2.new(0, x - 8, 0, y + height * (1 - healthPercent))
        esp.HealthBar.BackgroundColor3 = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
        esp.HealthBar.Visible = true
        
        -- Distance
        esp.Distance.Text = math.floor(distance) .. " studs"
        esp.Distance.Position = UDim2.new(0, x, 0, y + height + 2)
        esp.Distance.Size = UDim2.new(0, width, 0, 15)
        esp.Distance.Visible = true
    end
end

-- Get Closest Player
local function GetClosestPlayer(maxDist)
    maxDist = maxDist or math.huge
    local closest = nil
    local minDist = maxDist
    
    local mousePos = UserInputService:GetMouseLocation()
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        
        local char = player.Character
        if not char then continue end
        
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        
        local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
        if not onScreen then continue end
        
        -- Checks
        if char:FindFirstChild("Forcefield") then continue end
        if char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").Health <= 0 then continue end
        
        local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
        if dist < minDist then
            minDist = dist
            closest = player
        end
    end
    
    return closest
end

-- Check Camera Mode
local function GetCameraMode()
    local zoom = (Camera.CFrame.Position - Camera.Focus.Position).Magnitude
    local isFirstPerson = zoom < 2
    local isShiftLocked = UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter
    
    return {
        FirstPerson = isFirstPerson,
        ThirdPerson = not isFirstPerson,
        ShiftLocked = isShiftLocked
    }
end

-- Camlock Function
local function DoCamlock()
    if not Config.Camlock then return end
    if not State.CamlockTarget then return end
    
    local char = State.CamlockTarget.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Check camera mode
    local mode = GetCameraMode()
    if mode.ThirdPerson and not mode.ShiftLocked then
        return -- Don't work in third person unless shift locked
    end
    
    -- Get target position
    local targetPos = root.Position
    local velocity = root.Velocity
    
    -- Apply prediction
    targetPos = targetPos + Vector3.new(
        velocity.X * Config.CamlockPrediction,
        velocity.Y * Config.CamlockPrediction,
        velocity.Z * Config.CamlockPrediction
    )
    
    -- Smooth camlock
    local targetCF = CFrame.new(Camera.CFrame.Position, targetPos)
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, Config.CamlockSmoothness)
end

-- Silent Aim Function
local function DoSilentAim(tool)
    if not Config.SilentAim then return end
    if not State.SilentAimTarget then return end
    
    local char = State.SilentAimTarget.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Fire remote with target position
    local targetPos = root.Position + Vector3.new(0, 1, 0) -- Aim at upper body
    
    -- Get tool handle
    local handle = tool:FindFirstChild("Handle")
    if not handle then return end
    
    -- Fire the gun event
    local remote = tool:FindFirstChild("RemoteEvent")
    if remote then
        remote:FireServer("Shoot")
        
        -- Fire main event
        local origin = handle.Position
        ReplicatedStorage.MainEvent:FireServer("ShootGun", handle, origin, targetPos, nil, nil, Workspace:GetServerTimeNow())
        
        remote:FireServer()
    end
end

-- Walkspeed
local function UpdateWalkSpeed()
    local char = LocalPlayer.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    if Config.WalkSpeedEnabled then
        humanoid.WalkSpeed = Config.WalkSpeed
    else
        humanoid.WalkSpeed = 16
    end
end

-- Input Handling
AddConnection(UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    -- Silent Aim Toggle (O)
    if input.KeyCode == Config.SilentAimKey then
        Config.SilentAim = not Config.SilentAim
        if Config.SilentAim then
            State.SilentAimTarget = GetClosestPlayer(1000)
        else
            State.SilentAimTarget = nil
        end
        UpdateUI()
    end
    
    -- Camlock Toggle (V)
    if input.KeyCode == Config.CamlockKey then
        Config.Camlock = not Config.Camlock
        if Config.Camlock then
            State.CamlockTarget = GetClosestPlayer(1000)
        else
            State.CamlockTarget = nil
        end
        UpdateUI()
    end
    
    -- ESP Toggle (P)
    if input.KeyCode == Config.ESPKey then
        Config.ESP = not Config.ESP
        UpdateUI()
    end
    
    -- WalkSpeed Toggle (G)
    if input.KeyCode == Config.WalkSpeedKey then
        Config.WalkSpeedEnabled = not Config.WalkSpeedEnabled
        UpdateWalkSpeed()
        UpdateUI()
    end
end))

-- Character added
AddConnection(LocalPlayer.CharacterAdded:Connect(function(char)
    -- Setup tool activation for silent aim
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") and child:FindFirstChild("RemoteEvent") then
            child.Activated:Connect(function()
                DoSilentAim(child)
            end)
        end
    end)
    
    -- Apply walkspeed
    task.wait(0.1)
    UpdateWalkSpeed()
end))

-- Setup current character
if LocalPlayer.Character then
    LocalPlayer.Character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") and child:FindFirstChild("RemoteEvent") then
            child.Activated:Connect(function()
                DoSilentAim(child)
            end)
        end
    end)
end

-- Main Loop
AddConnection(RunService.RenderStepped:Connect(function()
    -- Update targets
    if Config.SilentAim and not State.SilentAimTarget then
        State.SilentAimTarget = GetClosestPlayer(1000)
    elseif not Config.SilentAim then
        State.SilentAimTarget = nil
    end
    
    if Config.Camlock and not State.CamlockTarget then
        State.CamlockTarget = GetClosestPlayer(1000)
    elseif not Config.Camlock then
        State.CamlockTarget = nil
    end
    
    -- Update features
    DoCamlock()
    UpdateESP()
    UpdateUI()
end))

