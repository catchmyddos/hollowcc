local function IsBot(player)
    -- Check if player is a bot (Da Track)
    if not player then return false end
    local name = player.Name:lower()
    return name:find("bot") or name:find("npc") or name:find("dummy") or 
           name:find("target") or player.UserId < 1
end

local function CreateESP(player)
