    return toolName:gsub("%[", ""):gsub("%]", ""):gsub(" ", ""):lower()
end

local function getInventoryItems()
    local inventory = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                inventory[getCleanToolName(item.Name)] = true
                inventory[item.Name:lower()] = true
            end
        end
    end
    
    if char then
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                inventory[getCleanToolName(item.Name)] = true
                inventory[item.Name:lower()] = true
            end
        end
    end
    
    return inventory
end

local function clickAllowedPads()
    if not BuyPads or not GameConfig then return end
    if IsRespawning then return end
    
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    
    local waitStart = tick()
    while backpack and #backpack:GetChildren() == 0 and (tick() - waitStart) < 3 do
        task.wait(0.1)
    end
    
    if IsRespawning then return end
    
    for _, itemName in ipairs(GameConfig.allowedpads) do
        local pad = BuyPads:FindFirstChild(itemName, true)
        if not pad then 
            local cleanPadName = getCleanToolName(itemName)
            for _, child in ipairs(BuyPads:GetDescendants()) do
                if child.Name == itemName or getCleanToolName(child.Name) == cleanPadName then
                    pad = child
                    break
                end
            end
        end
        
        if not pad then continue end
        
        local shouldBuy = true
        local cleanName = itemName:match("^%[(.+)%]$") or itemName
        local gameWeaponName = GUNS_MAP[cleanName]
        
        if gameWeaponName then
            if backpack then
                for _, item in ipairs(backpack:GetChildren()) do
                    if item:IsA("Tool") and (item.Name == gameWeaponName or getCleanToolName(item.Name) == gameWeaponName) then
                        shouldBuy = false
                        break
                    end
                end
            end
            
            if shouldBuy and char then
                local tool = char:FindFirstChildOfClass("Tool")
                if tool and (tool.Name == gameWeaponName or getCleanToolName(tool.Name) == gameWeaponName) then
                    shouldBuy = false
                end
            end
        end
        
        if cleanName:lower():find("armor") then
            local function checkForArmor(container)
                if not container then return false end
                for _, item in ipairs(container:GetChildren()) do
                    if item:IsA("Tool") then
                        local itemClean = getCleanToolName(item.Name)
                        if itemClean:find("armor") or itemClean:find("vest") then
                            return true
                        end
                    end
                end
                return false
            end
            
            if checkForArmor(backpack) or checkForArmor(char) then
                shouldBuy = false
            end
        end
        
        if shouldBuy and not IsRespawning then
            local cd = pad:FindFirstChildWhichIsA("ClickDetector")
            if cd then
                fireclickdetector(cd)
                task.wait(0.1)
            else
                for _, child in ipairs(pad:GetDescendants()) do
                    if child:IsA("ClickDetector") then
                        fireclickdetector(child)
                        task.wait(0.1)
                        break
                    end
                end
            end
        end
    end
end

local function ToggleAutoBuy()
    AutoBuyEnabled = not AutoBuyEnabled
    Notify("AutoBuy: " .. (AutoBuyEnabled and "ON" or "OFF"))
    if AutoBuyEnabled and GameConfig then
        clickAllowedPads()
    end
end

