local function GetClosestPlayerToMouse()
    local closest, dist = nil, math.huge
    local mousePos = UserInputService:GetMouseLocation()
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local char = plr.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            
            if hum and hrp and hum.Health > 0 then
                local knocked = char:GetAttribute("Knocked")
                local knockedVal = char:FindFirstChild("Knocked")
                if knocked == true or (knockedVal and knockedVal:IsA("BoolValue") and knockedVal.Value == true) then
                    continue
                end
                
                if Shoomedaware.Checks.WallCheck and not IsTargetVisible(plr) then
                    continue
                end
                
                local pos = Camera:WorldToViewportPoint(hrp.Position)
                if pos.Z > 0 then
                    local screenPos = Vector2.new(pos.X, pos.Y)
                    local d = (screenPos - mousePos).Magnitude
                    if d < dist then 
                        dist = d 
                        closest = plr 
                    end
                end
            end
        end
    end
    return closest
end

local function GetClosestBotToMouse()
    if not Shoomedaware.General.TargetBots then return nil end
    
    local closest, dist = nil, math.huge
    local mousePos = UserInputService:GetMouseLocation()
    
    for botChar, botData in pairs(BotCache) do
        if botChar and botChar.Parent and not IsBotDead(botChar) then
            local hrp = botChar:FindFirstChild("HumanoidRootPart")
            if hrp then
                if Shoomedaware.Checks.WallCheck and not IsTargetVisible(botChar) then
                    continue
                end
                
                local pos = Camera:WorldToViewportPoint(hrp.Position)
                if pos.Z > 0 then
                    local screenPos = Vector2.new(pos.X, pos.Y)
                    local d = (screenPos - mousePos).Magnitude
                    if d < dist then 
                        dist = d 
                        closest = botChar 
                    end
                end
            end
        end
    end
    
    return closest
end

local function GetTargetCharacter(target)
    if not target then return nil end
    if typeof(target) == "Instance" and target:IsA("Model") then
        return target
    elseif typeof(target) == "Instance" and target:IsA("Player") then
        return target.Character
    end
    return nil
end

local function GetTargetRootPart(target)
    local char = GetTargetCharacter(target)
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

