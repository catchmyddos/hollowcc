-- Cleanup function
_G.HollowCC_Cleanup = function()
    if State.ScreenGui then
        State.ScreenGui:Destroy()
    end
    if State.ESPFolder then
        State.ESPFolder:Destroy()
    end
    for _, conn in ipairs(State.Connections or {}) do
        pcall(function() conn:Disconnect() end)
    end
end

