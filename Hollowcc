-- CAMLOCK with adjustable smoothness
local function DoCamlock()
    if not State.Camlock then return end
    if not State.CamlockTarget then return end
    if not IsPlayerValid(State.CamlockTarget) then
        State.CamlockTarget = nil
        return
    end
    
    if not ShouldCamlockWork() then return end
    
    local char = State.CamlockTarget.Character
    local root = char:FindFirstChild(shared.Saved['C‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk']['H‚Äči‚Äčt‚Äč ‚ÄčP‚Äča‚Äčr‚Äčt']) or char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local targetPos = root.Position
    
    -- Apply prediction
    if shared.Saved['C‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk']['P‚Äčr‚Äče‚Äčd‚Äči‚Äčc‚Äčt‚Äči‚Äčo‚Äčn']['E‚Äčn‚Äča‚Äčb‚Äčl‚Äče‚Äčd'] then
        local velocity = root.Velocity
        targetPos = targetPos + Vector3.new(
            velocity.X * shared.Saved['C‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk']['P‚Äčr‚Äče‚Äčd‚Äči‚Äčc‚Äčt‚Äči‚Äčo‚Äčn']['X'],
            velocity.Y * shared.Saved['C‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk']['P‚Äčr‚Äče‚Äčd‚Äči‚Äčc‚Äčt‚Äči‚Äčo‚Äčn']['Y'],
            velocity.Z * shared.Saved['C‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk']['P‚Äčr‚Äče‚Äčd‚Äči‚Äčc‚Äčt‚Äči‚Äčo‚Äčn']['Z']
        )
    end
    
    -- Calculate smoothness
    local baseSmoothness = shared.Saved['C‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk']['S‚Äčm‚Äčo‚Äčo‚Äčt‚Äčh‚Äčn‚Äče‚Äčs‚Äčs']
    local smoothness = baseSmoothness
    
    -- Dynamic smoothness based on distance (reduces shake)
    if shared.Saved['C‚Äča‚Äčm‚Äčl‚Äčo‚Äčc‚Äčk']['D‚Äčy‚Äčn‚Äča‚Äčm‚Äči‚Äčc‚ÄčS‚Äčm‚Äčo‚Äčo‚Äčt‚Äčh‚Äčn‚Äče‚Äčs‚Äčs'] then
        local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if localRoot then
            local distance = (localRoot.Position - root.Position).Magnitude
            if distance < 10 then
                smoothness = math.clamp(smoothness * 1.5, 0.01, 0.3)
            elseif distance < 30 then
                smoothness = math.clamp(smoothness * 1.2, 0.01, 0.3)
            end
        end
    end
    
    -- Apply camlock
    -- NOTE: Higher smoothness = smoother/more legit (0.1-0.3)
    --       Lower smoothness = harder/snappier (0.01-0.05)
    local targetCF = CFrame.new(Camera.CFrame.Position, targetPos)
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, smoothness)
end

