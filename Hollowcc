}

local PRIORITY_PARTS = {
    "Head",
    "UpperTorso", 
    "LowerTorso",
    "HumanoidRootPart",
    "HB"
}

local function GetSimpleClosestPoint(character)
    if not (character and character.Parent) then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local mouseX, mouseY = mousePos.X, mousePos.Y
    
    local bestDist = 1e9
    local bestPart, bestPos, bestScreenPos
    
    for _, name in ipairs(PRIORITY_PARTS) do
        local part = character:FindFirstChild(name)
        if part and part:IsA("BasePart") then 
            local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                if dist < bestDist then 
                    bestDist = dist 
                    bestPart = part 
                    bestPos = part.Position
                    bestScreenPos = screenPos
                end
            end
        end
    end
    
    for _, name in ipairs(ALL_CHARACTER_PARTS) do
        local part = character:FindFirstChild(name)
        if part and part:IsA("BasePart") then 
            local size = part.Size
            local half = size * 0.5
            local cframe = part.CFrame
            
            local checkOffsets = {
                Vector3.new(0, 0, 0),
                Vector3.new(half.X * 0.5, half.Y * 0.5, half.Z * 0.5),
                Vector3.new(-half.X * 0.5, half.Y * 0.5, half.Z * 0.5),
                Vector3.new(half.X * 0.5, -half.Y * 0.5, half.Z * 0.5),
                Vector3.new(-half.X * 0.5, -half.Y * 0.5, half.Z * 0.5),
            }
            
            for _, offset in ipairs(checkOffsets) do
                local worldPos = cframe:PointToWorldSpace(offset)
                local screenPos, onScreen = Camera:WorldToViewportPoint(worldPos)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then 
                        bestDist = dist 
                        bestPart = part 
                        bestPos = worldPos
                        bestScreenPos = screenPos
                    end
                end
            end
        end
    end
    
    if bestPart then 
        return {Part = bestPart, Position = bestPos, ScreenPosition = bestScreenPos}
    else
        local root = character:FindFirstChild("HumanoidRootPart")
        return root and {Part = root, Position = root.Position, ScreenPosition = Camera:WorldToViewportPoint(root.Position)}
    end
end

local function GetHitPartDataUniversal(character, configSection)
    if not character then return nil, nil, Vector3.new(), Vector3.new() end
    
    local hitPartSetting = configSection['Hit Part']
    if hitPartSetting == "Closest Point" then
        local data = GetSimpleClosestPoint(character)
        if data then
            local virtualPart = {
                Position = data.Position, 
                Velocity = data.Part.Velocity or Vector3.new(), 
                Size = data.Part.Size,
                Name = data.Part.Name
            }
            return virtualPart, data.Part, data.Position, data.Part.Velocity or Vector3.new()
        end
    end
    
    if hitPartSetting and hitPartSetting ~= "Closest Point" then
        local specificPart = character:FindFirstChild(hitPartSetting)
        if specificPart and specificPart:IsA("BasePart") then
            return specificPart, specificPart, specificPart.Position, specificPart.Velocity or Vector3.new()
        end
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp, hrp, hrp.Position, hrp.Velocity or Vector3.new() end
    
    local head = character:FindFirstChild("Head")
    if head then return head, head, head.Position, head.Velocity or Vector3.new() end
    
    return nil, nil, Vector3.new(), Vector3.new()
end

local function IsMouseInTargetFOV(target, fovConfig)
    if not fovConfig.Enabled then return true end
    if not fovConfig.RequireMouseInFOV then return true end
    if not target then return false end
    
    local hrp = GetTargetRootPart(target)
    if not hrp then return false end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
    if not onScreen then return false end
    
    local mousePos = UserInputService:GetMouseLocation()
    
    if fovConfig.Mode == "2D" then
        local cfg = fovConfig["2D"]
        local fovWidth = cfg.X or 60
        local fovHeight = cfg.Y or 100
        
        local boxLeft = screenPos.X - fovWidth
        local boxRight = screenPos.X + fovWidth
        local boxTop = screenPos.Y - fovHeight
        local boxBottom = screenPos.Y + fovHeight
        
        return mousePos.X >= boxLeft and mousePos.X <= boxRight and 
               mousePos.Y >= boxTop and mousePos.Y <= boxBottom
    else
        local camPos = Camera.CFrame.Position
        local direction = (hrp.Position - camPos).Unit
        local forward = Camera.CFrame.LookVector
        local angle = math.acos(forward:Dot(direction)) * (180 / math.pi)
        return angle < (fovConfig["3D"].X or 150)
    end
end

