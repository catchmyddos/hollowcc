local function GetClosestPartForSilent(character)
    local head = character:FindFirstChild("Head")
    if head then return head, head.Position end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp, hrp.Position end
    
    local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
    if torso then return torso, torso.Position end
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            return part, part.Position
        end
    end
    
    return nil, nil
end

local function PredictTargetPosition(target, hitPart, basePred)
    if not target then return nil end
    
    local hrp
    if typeof(target) == "Instance" and target:IsA("Model") then
        hrp = target:FindFirstChild("HumanoidRootPart")
    else
        hrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    end
    
    if not hrp then return nil end
    if not hitPart then hitPart = hrp end
    
    if basePred.X == 0 and basePred.Y == 0 and basePred.Z == 0 then
        return hitPart.CFrame.Position
    end
    
    local velocity = hrp.Velocity
    local targetPos = hitPart.Position
    
    local velMag = velocity.Magnitude
    if velMag > 350 then
        velocity = velocity.Unit * 350
    end
    
    local predictedPos = Vector3.new(
        targetPos.X + (velocity.X * basePred.X),
        targetPos.Y + (velocity.Y * basePred.Y),
        targetPos.Z + (velocity.Z * basePred.Z)
    )
    
    LastPrediction = predictedPos
    LastPredictionTime = tick()
    
    return predictedPos
end

local LastSilentAimCheck = 0
local CachedSilentAimResult = nil

if getrawmetatable then
    local mt = getrawmetatable(game)
    if mt then
        local old = mt.__index
        setreadonly(mt, false)
        
        mt.__index = function(self, k)
            if self ~= CachedMouse then return old(self, k) end
            if k ~= "Hit" and k ~= "Target" then return old(self, k) end
            
            local silentActive = Shoomedaware.SilentAim.Enabled or 
                (Shoomedaware.General.TargetingMode == "Automatic" and Shoomedaware.AutoTargetActive)
            
            if not silentActive then return old(self, k) end
            if tick() - TargetAcquiredTime < TARGET_LOCK_IN_DELAY then return old(self, k) end
            
            local t = CurrentTarget or CurrentBotTarget
            if not t then return old(self, k) end
            
            if not IsMouseInTargetFOV(t, Shoomedaware.SilentAim.FOV) then
                return old(self, k)
            end
            
            local now = tick()
            if CachedSilentAimResult and (now - LastSilentAimCheck) < 0.016 then
                if k == "Hit" then return CachedSilentAimResult.Hit
                elseif k == "Target" then return CachedSilentAimResult.Target end
            end
            
            if not IsValidTarget(t) then return old(self, k) end
            if Shoomedaware.Checks.WallCheck and not IsTargetVisible(t) then return old(self, k) end
            
            local char = GetTargetCharacter(t)
            if not char then return old(self, k) end
            
            local realPart, basePos
            local isZeroPred = Shoomedaware.SilentAim.Prediction.X == 0 and 
                              Shoomedaware.SilentAim.Prediction.Y == 0 and 
                              Shoomedaware.SilentAim.Prediction.Z == 0
            
            if isZeroPred then
                local closestData = GetSimpleClosestPoint(char)
                if closestData then
                    realPart = closestData.Part
                    basePos = closestData.Position
                end
            else
                local virtualPart, rp, pos, vel = GetHitPartDataUniversal(char, Shoomedaware.SilentAim)
                realPart = rp
                basePos = pos
            end
            
            if not realPart or not basePos then return old(self, k) end
            if IsBehindWall(realPart) then return old(self, k) end
            
            local basePred = Shoomedaware.SilentAim.Prediction
            
            if Shoomedaware.SilentAim.UseSeparateGunPredictions then
                local myChar = LocalPlayer.Character
                if myChar then
                    local tool = myChar:FindFirstChildOfClass("Tool")
                    if tool then
                        local toolName = tool.Name:lower()
                        local gunPred = Shoomedaware.SilentAim.GunPredictions[toolName] 
                            or Shoomedaware.SilentAim.GunPredictions["Default"]
                        if gunPred then
                            basePred = gunPred
                        end
                    end
                end
            end
            
            local predictedPos = PredictTargetPosition(t, realPart, basePred)
            
            if not predictedPos then
                predictedPos = basePos
            end
            
            if not (basePred.X == 0 and basePred.Y == 0 and basePred.Z == 0) then
                if Shoomedaware.SilentAim.HitChance < 100 and math.random(1, 100) > Shoomedaware.SilentAim.HitChance then
                    return old(self, k)
                end
            end
            
            SilentAimCache.LastTarget = realPart
            SilentAimCache.LastPosition = predictedPos
            SilentAimCache.LastCFrame = CFrame.new(predictedPos)
            
            CachedSilentAimResult = {
                Hit = CFrame.new(predictedPos),
                Target = realPart
            }
            LastSilentAimCheck = now
            
            if k == "Hit" then return CachedSilentAimResult.Hit
            elseif k == "Target" then return CachedSilentAimResult.Target end
        end
        
        setreadonly(mt, true)
    end
end

