local function GetNetworkPing()
    local success, ping = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    if success and ping then return ping end
    success, ping = pcall(function() return LocalPlayer:GetNetworkPing() end)
    return success and ping or 50
end

local function UpdatePingHistory()
    local currentPing = GetNetworkPing()
    table.insert(AutoPredState.PingHistory, 1, currentPing)
    if #AutoPredState.PingHistory > 10 then table.remove(AutoPredState.PingHistory) end
    local sum = 0
    for _, ping in ipairs(AutoPredState.PingHistory) do sum = sum + ping end
    AutoPredState.AveragePing = sum / #AutoPredState.PingHistory
end

local function UpdateAutoPrediction()
    if not Shoomedaware.SilentAim.AutoPrediction.Enabled then return end
    local currentTime = tick()
    local cfg = Shoomedaware.SilentAim.AutoPrediction
    if currentTime - AutoPredState.LastUpdate < cfg.Interval then return end
    AutoPredState.LastUpdate = currentTime
    UpdatePingHistory()
    
    local target = CurrentTarget or CurrentBotTarget
    local newPred
    
    if cfg.Mode == "Ping" then
        local ping = AutoPredState.AveragePing
        local base = cfg.BasePrediction
        local pingFactor = ping * cfg.PingMultiplier
        newPred = {
            X = math.clamp(base.X + pingFactor, cfg.MinPrediction.X, cfg.MaxPrediction.X),
            Y = math.clamp(base.Y + pingFactor, cfg.MinPrediction.Y, cfg.MaxPrediction.Y),
            Z = math.clamp(base.Z + pingFactor, cfg.MinPrediction.Z, cfg.MaxPrediction.Z),
        }
    else
        newPred = cfg.BasePrediction
    end
    
    if not newPred then return end
    
    local smoothing = cfg.Smoothing or 0.3
    AutoPredState.CurrentPrediction = {
        X = AutoPredState.CurrentPrediction.X + (newPred.X - AutoPredState.CurrentPrediction.X) * smoothing,
        Y = AutoPredState.CurrentPrediction.Y + (newPred.Y - AutoPredState.CurrentPrediction.Y) * smoothing,
        Z = AutoPredState.CurrentPrediction.Z + (newPred.Z - AutoPredState.CurrentPrediction.Z) * smoothing,
    }
    
    Shoomedaware.SilentAim.Prediction = {
        X = AutoPredState.CurrentPrediction.X,
        Y = AutoPredState.CurrentPrediction.Y,
        Z = AutoPredState.CurrentPrediction.Z,
    }
end

AddConnection(RunService.Heartbeat:Connect(UpdateAutoPrediction))

