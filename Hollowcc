if Shoomedaware.ModDetector and Shoomedaware.ModDetector.Enabled then
    task.spawn(function()
        while _G.ShoomedawareActive do
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    local isMod = false
                    if Shoomedaware.ModDetector.GroupId then
                        local success, inGroup = pcall(function()
                            return plr:IsInGroup(Shoomedaware.ModDetector.GroupId)
                        end)
                        if success and inGroup then
                            isMod = true
                        end
                    end
                    
                    if not isMod and Shoomedaware.ModDetector.UserIds then
                        for _, id in ipairs(Shoomedaware.ModDetector.UserIds) do
                            if plr.UserId == id then
                                isMod = true
                                break
                            end
                        end
                    end
                    
                    if isMod then
                        Notify("MOD DETECTED: " .. plr.Name)
                        if Shoomedaware.ModDetector.KickOnMod then
                            LocalPlayer:Kick("Mod detected: " .. plr.Name)
                            return
                        end
                    end
                end
            end
            task.wait(5)
        end
    end)
end

