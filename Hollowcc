local function IsDaTrack()
    return game.PlaceId == 75159825516372
end

local function GetBotsFolder()
    if not IsDaTrack() then return nil end
    return Workspace:FindFirstChild("Bots")
end

local function IsBotCharacter(char)
    if not char then return false end
    local botsFolder = GetBotsFolder()
    if botsFolder and char:IsDescendantOf(botsFolder) then
        return true
    end
    if char.Name:find("Bot") then
        return true
    end
    return false
end

local function GetBotHealth(char)
    if not char then return 0, 100 end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        return hum.Health, hum.MaxHealth
    end
    local healthVal = char:FindFirstChild("Health")
    if healthVal and healthVal:IsA("NumberValue") then
        return healthVal.Value, 100
    end
    return 100, 100
end

local function IsBotDead(char)
    if not char then return true end
    
    if char.Parent == nil then return true end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then return true end
    
    local healthVal = char:FindFirstChild("Health")
    if healthVal and healthVal:IsA("NumberValue") and healthVal.Value <= 0 then 
        return true 
    end
    
    local deadVal = char:FindFirstChild("Dead")
    if deadVal and deadVal:IsA("BoolValue") and deadVal.Value == true then
        return true
    end
    
    local knockedVal = char:FindFirstChild("Knocked")
    if knockedVal and knockedVal:IsA("BoolValue") and knockedVal.Value == true then
        return true
    end
    
    if char:GetAttribute("Dead") == true then return true end
    if char:GetAttribute("Knocked") == true then return true end
    
    if char.Parent and char.Parent.Name == "Debris" then return true end
    
    local health, _ = GetBotHealth(char)
    return health <= 0
end

local function UpdateBotCache()
    if not IsDaTrack() then return end
    if not Shoomedaware.General.TargetBots then return end
    
    local botsFolder = GetBotsFolder()
    if not botsFolder then return end
    
    BotCache = {}
    for _, bot in ipairs(botsFolder:GetChildren()) do
        if bot:IsA("Model") and bot:FindFirstChild("HumanoidRootPart") then
            if not IsBotDead(bot) then
                BotCache[bot] = {
                    Character = bot,
                    IsBot = true,
                    Name = bot.Name,
                    Health = GetBotHealth(bot),
                }
            end
        end
    end
end

