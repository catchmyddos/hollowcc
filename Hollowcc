    task.wait(0.1)
    UpdateWallCheckFilter()
end))

if LocalPlayer.Character then UpdateWallCheckFilter() end

local function IsTargetVisible(target)
    if not Shoomedaware.Checks.WallCheck then return true end
    if not target then return false end
    
    local char
    if typeof(target) == "Instance" and target:IsA("Model") then
        char = target
    elseif target.Character then
        char = target.Character
    else
        return false
    end
    
    local myChar = LocalPlayer.Character
    if not myChar then return false end
    
    local myHead = myChar:FindFirstChild("Head")
    if not myHead then return false end
    
    local myPos = myHead.Position
    
    local checkPoints = {
        char:FindFirstChild("Head"),
        char:FindFirstChild("HumanoidRootPart"),
        char:FindFirstChild("UpperTorso"),
        char:FindFirstChild("LowerTorso"),
    }
    
    for _, part in ipairs(checkPoints) do
        if part and part:IsA("BasePart") then
            local direction = (part.Position - myPos)
            local distance = direction.Magnitude
            
            if distance > 1000 then continue end
            
            direction = direction.Unit * distance
            
            local result = Workspace:Raycast(myPos, direction, WallCheckParams)
            
            if not result then
                return true
            end
            
            if result.Instance then
                local hitModel = result.Instance:FindFirstAncestorOfClass("Model")
                if hitModel == char or result.Instance:IsDescendantOf(char) then
                    return true
                end
            end
        end
    end
    
    return false
end

local function IsBehindWall(part)
    if not part then return true end
    if not Shoomedaware.Checks.WallCheck then return false end
    
    local myChar = LocalPlayer.Character
    local myHead = myChar and myChar:FindFirstChild("Head")
    if not myHead then return true end
    
    local direction = part.Position - myHead.Position
    local distance = direction.Magnitude
    
    if distance > 500 then return true end
    
    local result = Workspace:Raycast(myHead.Position, direction, WallCheckParams)
    
    if not result then return false end
    
    if result.Instance then
        local hitChar = result.Instance:FindFirstAncestorOfClass("Model")
        local targetChar = part:FindFirstAncestorOfClass("Model")
        if hitChar == targetChar or result.Instance:IsDescendantOf(targetChar) then
            return false
        end
    end
    
    return true
end

local function HasForceField(char)
    if not Shoomedaware.Checks.ForceFieldCheck then return false end
    if not char then return false end
    if char:FindFirstChildOfClass("ForceField") then return true end
    if char:GetAttribute("ForceField") then return true end
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("ForceField") then return true end
    end
    return false
end

local function IsKnocked(char)
    if not Shoomedaware.Checks.KnockCheck then return false end
    if not char then return true end
    
    if IsBotCharacter(char) then
        return IsBotDead(char)
    end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return true end
    
    local knockedAttr = char:GetAttribute("Knocked")
    if knockedAttr == true then return true end
    
    local knockedVal = char:FindFirstChild("Knocked")
    if knockedVal and knockedVal:IsA("BoolValue") and knockedVal.Value == true then return true end
    
    return false
end

local function HasKatana(char)
    if not Shoomedaware.Checks.KatanaCheck then return false end
    if not char then return false end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local name = tool.Name:lower()
            if name:find("katana") or name:find("knife") then
                return true
            end
        end
    end
    return false
end

local function IsValidTarget(plr, forESP)
    if not plr then return false end
    
    if typeof(plr) == "Instance" and plr:IsA("Model") then
        if IsBotCharacter(plr) then
            if not Shoomedaware.General.TargetBots then return false end
            if IsBotDead(plr) then return false end
            
            local hrp = plr:FindFirstChild("HumanoidRootPart")
            if not hrp then return false end
            
            if Shoomedaware.Checks.ForceFieldCheck and HasForceField(plr) then return false end
            if Shoomedaware.Checks.KatanaCheck and HasKatana(plr) then return false end
            
            return true
        end
        return false
    end
    
    if not plr.Character or plr == LocalPlayer then return false end
    local char = plr.Character
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    
    if not forESP and hum.Health <= 0 then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    if Shoomedaware.Checks.ForceFieldCheck and HasForceField(char) then return false end
    if Shoomedaware.Checks.KatanaCheck and HasKatana(char) then return false end
    
    if not forESP and Shoomedaware.Checks.KnockCheck then
        local knockedAttr = char:GetAttribute("Knocked")
        if knockedAttr == true then return false end
        
        local knockedVal = char:FindFirstChild("Knocked")
        if knockedVal and knockedVal:IsA("BoolValue") and knockedVal.Value == true then return false end
    end
    
    return true
end

