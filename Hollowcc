-- Update Hollow.cc UI
local StatusLabels = {}
local function UpdateHollowUI()
    if not shared.HollowCC_Config['UI']['Enabled'] then
        HollowFrame.Visible = false
        return
    end
    
    HollowFrame.Visible = true
    HollowFrame.Position = shared.HollowCC_Config['UI']['Position']
    
    -- Clear old labels
    for _, label in pairs(StatusLabels) do
        label:Destroy()
    end
    StatusLabels = {}
    
    local Config = shared.HollowCC_Config
    
    -- Create status entries
    local function AddStatus(name, enabled, target)
        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, 0, 0, 18)
        Label.BackgroundTransparency = 1
        Label.TextSize = 14
        Label.Font = Config['UI']['TextBold'] and Enum.Font.SourceSansBold or Enum.Font.SourceSans
        Label.TextXAlignment = Enum.TextXAlignment.Right
        
        local statusText = enabled and "ON" or "OFF"
        local statusColor = enabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
        
        if Config['UI']['ShowToggles'] then
            if target and enabled then
                Label.Text = name .. ": " .. statusText .. " | " .. target
            else
                Label.Text = name .. ": " .. statusText
            end
            Label.TextColor3 = Config['UI']['TextColor']
        else
            if target and enabled then
                Label.Text = name .. ": " .. target
            else
                Label.Text = name .. ": " .. (enabled and "Active" or "None")
            end
            Label.TextColor3 = Config['UI']['TextColor']
        end
        
        Label.Parent = HollowContent
        table.insert(StatusLabels, Label)
    end
    
    -- Add all statuses
    AddStatus("Silent Aim", Script.Locals.IsSilentAiming, Script.Locals.SilentAimTarget and Script.Locals.SilentAimTarget.DisplayName or nil)
    AddStatus("Camlock", Script.Locals.IsCamlocking, Script.Locals.CamlockTarget and Script.Locals.CamlockTarget.DisplayName or nil)
    AddStatus("Triggerbot", Script.Locals.TriggerState, Script.Locals.TriggerbotTarget and Script.Locals.TriggerbotTarget.DisplayName or nil)
    AddStatus("ESP", Config['ESP']['Enabled'], nil)
    AddStatus("WalkSpeed", Script.Locals.IsWalkSpeeding, nil)
    AddStatus("Double Tap", Script.Locals.IsDoubleTapping, nil)
    
    -- Adjust frame size
    local contentHeight = #StatusLabels * 20 + 35
    HollowFrame.Size = UDim2.new(0, 200, 0, contentHeight)
end

