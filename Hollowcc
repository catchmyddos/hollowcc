AddConnection(UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    local kc = ""
    if input.KeyCode and input.KeyCode ~= Enum.KeyCode.Unknown then
        kc = input.KeyCode.Name:upper()
    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
        kc = "MOUSEBUTTON1"
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
        kc = "MOUSEBUTTON2"
    end
    
    if kc == "" then return end
    
    for feature, key in pairs(Shoomedaware.General.Binds) do
        if tostring(key):upper() == kc then
            if feature == "ESP" then
                Shoomedaware.ESPSettings.Enabled = not Shoomedaware.ESPSettings.Enabled
                
            elseif feature == "SilentAimToggle" then
                if Shoomedaware.RequireManualRetoggle then
                    Shoomedaware.RequireManualRetoggle = false
                end
                
                if Shoomedaware.General.TargetingMode == "Automatic" then
                    Shoomedaware.AutoTargetActive = not Shoomedaware.AutoTargetActive
                    if not Shoomedaware.AutoTargetActive then 
                        CurrentTarget = nil 
                        CurrentBotTarget = nil
                    end
                    Notify("Auto-Target: " .. (Shoomedaware.AutoTargetActive and "ON" or "OFF"))
                else
                    Shoomedaware.SilentAim.Enabled = not Shoomedaware.SilentAim.Enabled
                    
                    if Shoomedaware.SilentAim.Enabled then 
                        Shoomedaware.AcquireNewTarget = true 
                        task.spawn(function()
                            task.wait(0.05)
                            if not CurrentTarget and not CurrentBotTarget then
                                AcquireTarget()
                            end
                        end)
                    end
                end
                
            elseif feature == "AimAssistToggle" then
                if Shoomedaware.RequireManualRetoggle then
                    Shoomedaware.RequireManualRetoggle = false
                end
                
                if Shoomedaware.General.AimAssistMode == "Hold" then
                    HoldStates.AimAssist = true
                    AcquireTarget()
                else
                    Shoomedaware.AimAssist.Enabled = not Shoomedaware.AimAssist.Enabled
                    
                    if Shoomedaware.AimAssist.Enabled then 
                        Shoomedaware.AcquireNewTarget = true 
                        task.spawn(function()
                            task.wait(0.05)
                            if not CurrentTarget and not CurrentBotTarget then
                                AcquireTarget()
                            end
                        end)
                    end
                end
                
            elseif feature == "TriggerBotToggle" then
                if Shoomedaware.RequireManualRetoggle then
                    Shoomedaware.RequireManualRetoggle = false
                end
                
                if Shoomedaware.General.TriggerBotMode == "Hold" then
                    HoldStates.TriggerBot = true
                    AcquireTarget()
                else
                    Shoomedaware.TriggerBot.Enabled = not Shoomedaware.TriggerBot.Enabled
                    
                    if Shoomedaware.TriggerBot.Enabled then 
                        Shoomedaware.AcquireNewTarget = true 
                        task.spawn(function()
                            task.wait(0.05)
                            if not CurrentTarget and not CurrentBotTarget then
                                AcquireTarget()
                            end
                        end)
                    end
                end
                
            elseif feature == "AutoBuyToggle" then
                ToggleAutoBuy()
            end
        end
    end
end))

