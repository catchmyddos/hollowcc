local function ThreadLoop(Wait, Func)
    task.spawn(function()
        while true do
            local Delta = task.wait(Wait)
            local Success, Result = pcall(Func, Delta)
            if not Success then
                warn("Thread error:", Result)
            elseif Result == "break" then
                break
            end
        end
    end)
end

