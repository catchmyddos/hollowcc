    if Script.Locals.IsCamlocking and not Script.Locals.CamlockTarget then
        Script.Locals.CamlockTarget = Script:GetClosestPlayerToCursor(
            Config['Camlock']['FOV']['Enabled'] and Config['Camlock']['FOV']['Size'] or math.huge,
            math.huge
        )
    end
    
    -- Update Hollow.cc UI
    UpdateHollowUI()
    
    -- Update ESP
    UpdateESP()
    
    -- Run features
    Script:AimAssist()
    Script:Camlock()
    Script:Triggerbot()
    Script:Physics()
end)

